# Local OpenClio API settings for Synthesis wrapper helpers.
# Copy to integrations/synthesis/.openclio.env if you want a local helper config.

OPENCLIO_BASE_URL="http://127.0.0.1:18789"

# Optional. If omitted, helpers try to read ~/.openclio/auth.token
OPENCLIO_TOKEN=""

# Optional alternate data dir if you keep auth.token elsewhere
OPENCLIO_DATA_DIR=""
